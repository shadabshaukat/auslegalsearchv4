# ========================================
# AUSLegalSearch Production v2 Environment
# ========================================

# Optional override file path loader:
# export AUSLEGALSEARCH_V2_ENV_FILE=.env.production_v2

# OpenSearch connection (v2 can reuse cluster but uses NEW indexes)
V2_OPENSEARCH_HOST=https://amaaaaaawiclygaaf2cmcdbwtqc5umdzbschzy6zidvdxg5w4kywidp6j6xa.opensearch.us-sanjose-1.oci.oraclecloud.com:9200
V2_OPENSEARCH_USER=adminos
V2_OPENSEARCH_PASS='RAbbithole1234##'
V2_OPENSEARCH_VERIFY_CERTS=1
V2_OPENSEARCH_TIMEOUT=120
# Safety guard: keep 0 in production. Set 1 only for local OpenSearch dev.
V2_ALLOW_LOCALHOST_OPENSEARCH=0

# New v2 index names (ingest from scratch; no backfill of old indexes)
V2_INDEX_AUTHORITIES=austlii_authorities_v1
V2_INDEX_CHUNKS_LEX=austlii_chunks_lex_v1
V2_INDEX_CHUNKS_VEC=austlii_chunks_vec_v1
V2_INDEX_CITATION_GRAPH=austlii_citation_graph_v1

# Embeddings / chunking
# Accuracy-first legal embedding recommendation (if available in your environment)
# V2_EMBED_MODEL=maastrichtlawtech/bge-legal-en-v1.5
# Stable high-quality default:
V2_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
V2_EMBED_DIM=768
V2_EMBED_BATCH=64

# Accuracy-first reranking
V2_RERANK_ENABLE_DEFAULT=1
V2_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
V2_RERANK_TOP_N=50

V2_CHUNK_TARGET_TOKENS=512
V2_CHUNK_OVERLAP_TOKENS=64
V2_CHUNK_MAX_TOKENS=640
V2_CHUNK_MIN_SENTENCE_TOKENS=8
V2_CHUNK_MIN_CHUNK_TOKENS=60

# Ingestion throughput tuning (large corpora)
V2_INGEST_FILE_WORKERS=0
V2_INGEST_EMBED_BATCH=64
V2_INGEST_BULK_CHUNK_SIZE=800
V2_INGEST_STATUS_POLL_SECONDS=2
# Multi-GPU embedding sharding (optional)
# Example: V2_INGEST_GPU_IDS=0,1,2,3
V2_INGEST_GPU_IDS=0,1,2,3
V2_INGEST_MULTIGPU_MIN_TEXTS=256

# Host offload mode: keep FastAPI/Gradio in Docker, run ingestion natively on host.
V2_INGEST_OFFLOAD_ENABLE=1
V2_INGEST_OFFLOAD_WORKDIR=/home/ubuntu/auslegalsearchv4
V2_INGEST_OFFLOAD_START_CMD=AUSLEGALSEARCH_V2_ENV_FILE=/home/ubuntu/auslegalsearchv4/.env.production_v2 python3 -m production_v2.host_ingest_entry --job-id {job_id_q} --root-dir {root_dir_q} --limit-files {limit_files_q} --include-html {include_html}
V2_INGEST_OFFLOAD_STOP_CMD=AUSLEGALSEARCH_V2_ENV_FILE=/home/ubuntu/auslegalsearchv4/.env.production_v2 pkill -f "production_v2.host_ingest_entry --job-id {job_id}"

# API (FastAPI v2)
V2_API_HOST=0.0.0.0
V2_API_PORT=8010
V2_API_USER=legal_api
V2_API_PASS=letmein

# Gradio v2
V2_GRADIO_HOST=0.0.0.0
V2_GRADIO_PORT=7861
V2_GRADIO_API_URL=http://localhost:8010

# Docker ingest mount mapping (used by docker-compose variable substitution)
# Host folder with source corpus:
V2_HOST_INGEST_DIR=/home/ubuntu/auslegalsearchv4/sample-data-austlii-all-file-types
# Container-visible path to use in Gradio/API ingestion root_dir:
V2_CONTAINER_INGEST_DIR=/app/data
